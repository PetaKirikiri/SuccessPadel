VITE_SITE_URL=https://success-padel-ffzt.vercel.app
VITE_SUPABASE_URL=https://bknorpjoyxucrihnpyda.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard
VITE_LINE_CHANNEL_ID=
VITE_LINE_REDIRECT_URI=https://success-padel-ffzt.vercel.app/login
VITE_LIFF_ID=

# LINE Login (developers.line.biz → Success Padel channel):
#   Basic settings → Channel ID → VITE_LINE_CHANNEL_ID
#   LINE Login settings → Callback URL (must match exactly, no trailing slash):
#     https://success-padel-ffzt.vercel.app/login
#     https://success-padel-ffzt.vercel.app/auth/line/callback   (player linking)
#     successpadel://login   (Capacitor iOS/Android app)
#   Optional VITE_LINE_REDIRECT_URI — same URL, pinned for production builds
#   Supabase Edge Function secrets (not in frontend):
#     LINE_CHANNEL_ID, LINE_CHANNEL_SECRET
#   LIFF optional (only if opened inside LINE app — not used for Safari login):
#     LIFF tab → Endpoint https://success-padel-ffzt.vercel.app/ → VITE_LIFF_ID
#
# Native app / TestFlight (Capacitor iOS):
#   1. Copy this file to .env.production.local and fill VITE_* values (not committed).
#   2. npm run ios:release
#   3. Xcode → Archive → Upload to TestFlight
#   Bundle ID: app.successpadel.club
#   LINE callback (required): successpadel://login
#   Live reload on phone: CAP_SERVER_URL=http://YOUR_LAN_IP:5173 npm run cap:sync

# Phone testing without prod deploy (hotspot-friendly):
#   Terminal 1: npm run dev:phone
#   Terminal 2: npm run dev:tunnel
#   QR / LINE sign-up always uses liff.line.me → Vercel (VITE_SITE_URL). Tunnel is for UI testing only.
#   Open the tunnel URL on your phone (add to Supabase redirect URLs).
#
# Supabase Dashboard → Authentication → URL configuration → Redirect URLs:
#   http://localhost:5173/**
#   http://YOUR_PHONE_IP:5173/**
#   https://YOUR_TUNNEL.trycloudflare.com/**
#   https://success-padel-ffzt.vercel.app/**
#
# LINE LIFF endpoint is pinned in developers.line.biz — liff.line.me always loads that URL.
# For local LINE testing, temporarily set LIFF Endpoint to your tunnel URL, or use a dev LIFF app.
